# Local dev env template (copy to .env). Do NOT commit real secrets.

# ---- App URLs ----
WEB_ORIGIN=http://localhost:5173
API_ORIGIN=http://localhost:3000

# ---- Server ----
NODE_ENV=development
API_PORT=3000

# ---- Database (Postgres) ----
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/playbooked?schema=public

# ---- Redis (sessions) ----
REDIS_URL=redis://localhost:6379

# ---- Sessions ----
SESSION_SECRET=dev_only_change_me_to_a_long_random_string
SESSION_TTL_SECONDS=1209600

# ---- CSRF (double-submit) ----
CSRF_COOKIE_NAME=csrf_token
CSRF_HEADER_NAME=X-CSRF-Token

# ---- Logging / monitoring ----
SENTRY_DSN=
LOG_LEVEL=info
