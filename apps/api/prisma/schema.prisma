generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  INVESTOR @map("investor")
  ADMIN    @map("admin")
}

enum EventType {
  EARNINGS      @map("earnings")
  MACRO         @map("macro")
  COMPANY_EVENT @map("company_event")
  OTHER         @map("other")
}

enum EventStatus {
  UPCOMING  @map("upcoming")
  COMPLETED @map("completed")
}

enum PaperTradeStatus {
  PLANNED   @map("planned")
  OPEN      @map("open")
  CLOSED    @map("closed")
  CANCELLED @map("cancelled")
}

model User {
  id                    String          @id @default(uuid()) @db.Uuid
  email                 String          @unique @db.VarChar(320)
  passwordHash          String          @map("password_hash") @db.Text
  role                  UserRole        @default(INVESTOR)
  learningGoal          String?         @map("learning_goal") @db.Text
  defaultMaxLossPercent Decimal?        @map("default_max_loss_percent") @db.Decimal(5, 2)
  createdAt             DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  watchlistItems        WatchlistItem[]
  events                Event[]
  playbooks             Playbook[]
  paperTrades           PaperTrade[]
  gateAttempts          GateAttempt[]

  @@map("users")
}

model WatchlistItem {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  ticker    String   @db.VarChar(10)
  tagsJson  Json     @default("[]") @map("tags_json")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  events    Event[]

  @@unique([userId, ticker])
  @@unique([userId, id])
  @@map("watchlist_items")
}

model Event {
  id              String        @id @default(uuid()) @db.Uuid
  userId          String        @map("user_id") @db.Uuid
  watchlistItemId String        @map("watchlist_item_id") @db.Uuid
  eventType       EventType     @map("event_type")
  status          EventStatus   @default(UPCOMING)
  eventDatetimeAt DateTime      @map("event_datetime_at") @db.Timestamptz(6)
  completedAt     DateTime?     @map("completed_at") @db.Timestamptz(6)
  notes           String?       @db.Text
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  watchlistItem   WatchlistItem @relation(fields: [userId, watchlistItemId], references: [userId, id], onDelete: Cascade)
  playbook        Playbook?     @relation("EventPlaybook")
  gateAttempts    GateAttempt[]

  @@unique([userId, id])
  @@index([userId, status, eventDatetimeAt])
  @@map("events")
}

model Template {
  id                 String     @id @default(uuid()) @db.Uuid
  name               String     @db.VarChar(120)
  templateType       String     @map("template_type") @db.VarChar(80)
  version            Int        @default(1)
  checklistItemsJson Json       @default("[]") @map("checklist_items_json")
  createdAt          DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  playbooks          Playbook[]

  @@unique([name, version])
  @@map("templates")
}

model Playbook {
  id                 String        @id @default(uuid()) @db.Uuid
  userId             String        @map("user_id") @db.Uuid
  eventId            String        @unique @map("event_id") @db.Uuid
  templateId         String        @map("template_id") @db.Uuid
  thesis             String?       @db.Text
  keyMetricsJson     Json          @default("[]") @map("key_metrics_json")
  invalidationRule   String?       @map("invalidation_rule") @db.Text
  maxLossPercent     Decimal?      @map("max_loss_percent") @db.Decimal(5, 2)
  checklistStateJson Json          @default("{}") @map("checklist_state_json")
  isLocked           Boolean       @default(false) @map("is_locked")
  lockedAt           DateTime?     @map("locked_at") @db.Timestamptz(6)
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  event              Event         @relation("EventPlaybook", fields: [userId, eventId], references: [userId, id], onDelete: Cascade)
  template           Template      @relation(fields: [templateId], references: [id], onDelete: Restrict)
  paperTrades        PaperTrade[]
  gateAttempts       GateAttempt[]

  @@unique([userId, eventId])
  @@unique([userId, id])
  @@map("playbooks")
}

model PaperTrade {
  id              String           @id @default(uuid()) @db.Uuid
  userId          String           @map("user_id") @db.Uuid
  playbookId      String           @map("playbook_id") @db.Uuid
  ticker          String           @db.VarChar(10)
  status          PaperTradeStatus @default(PLANNED)
  entryPlan       String?          @map("entry_plan") @db.Text
  stopRule        String?          @map("stop_rule") @db.Text
  takeProfitRule  String?          @map("take_profit_rule") @db.Text
  positionSize    Decimal?         @map("position_size") @db.Decimal(18, 4)
  pnlPercent      Decimal?         @map("pnl_percent") @db.Decimal(8, 2)
  cancelReason    String?          @map("cancel_reason") @db.Text
  outcomeNotes    String?          @map("outcome_notes") @db.Text
  postMortemNotes String?          @map("post_mortem_notes") @db.Text
  openedAt        DateTime?        @map("opened_at") @db.Timestamptz(6)
  closedAt        DateTime?        @map("closed_at") @db.Timestamptz(6)
  cancelledAt     DateTime?        @map("cancelled_at") @db.Timestamptz(6)
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  playbook        Playbook         @relation(fields: [userId, playbookId], references: [userId, id], onDelete: Cascade)
  gateAttempts    GateAttempt[]    @relation("CreatedPaperTrade")

  @@index([userId, status, createdAt])
  @@index([userId, closedAt])
  @@map("paper_trades")
}

model GateAttempt {
  id                            String      @id @default(uuid()) @db.Uuid
  userId                        String      @map("user_id") @db.Uuid
  playbookId                    String      @map("playbook_id") @db.Uuid
  eventId                       String      @map("event_id") @db.Uuid
  createdPaperTradeId           String?     @map("created_paper_trade_id") @db.Uuid
  blockedByExistingPlannedTrade Boolean     @default(false) @map("blocked_by_existing_planned_trade")
  gateResultsJson               Json?       @map("gate_results_json")
  passedGateCount               Int?        @map("passed_gate_count")
  totalGates                    Int         @default(5) @map("total_gates")
  allPassed                     Boolean     @default(false) @map("all_passed")
  attemptedAt                   DateTime    @default(now()) @map("attempted_at") @db.Timestamptz(6)
  user                          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  playbook                      Playbook    @relation(fields: [userId, playbookId], references: [userId, id], onDelete: Cascade)
  event                         Event       @relation(fields: [userId, eventId], references: [userId, id], onDelete: Cascade)
  createdPaperTrade             PaperTrade? @relation("CreatedPaperTrade", fields: [createdPaperTradeId], references: [id], onDelete: SetNull)

  @@index([userId, attemptedAt])
  @@map("gate_attempts")
}
